  "author": "Shawn Nichols Sr. (Nichols Transco LLC)",
  "license": "MIT",
  "devDependencies": {
    "@dqbd/tiktoken": "^1.0.22",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  }
