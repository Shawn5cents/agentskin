{
  "name": "agentskin",
  "version": "4.2.1",
  "description": "AgentSkin: The official reference implementation of the Semantic Shorthand Standard (SSS) for Agentic Perception.",
  "type": "module",
  "main": "backend/mcp.js",
  "bin": {
    "agentskin": "backend/mcp.js"
  },
  "files": [
    "backend/",
    "README.md",
    "LICENSE",
    "docs/",
    "MANIFESTO.md",
    "PROJECT_STATE.md"
  ],
  "scripts": {
