{
  "name": "agentskin",
  "version": "5.0.0",
  "description": "AgentSkin Suite: Three-layer token optimization stack — AgentSkin SSS (JSON pruning) + Tokenjuice (CLI compaction) + Caveman (output compression). 88%+ API savings, 99.8% CLI savings, 4,695 tests.",
  "type": "module",
  "main": "backend/mcp.js",
  "bin": {
    "agentskin": "backend/mcp.js"
  },
  "files": [
    "backend/",
    "backend/package.json",
    "backend/package-lock.json",
    "README.md",
    "LICENSE",
    "docs/",
    "MANIFESTO.md",
    "PROJECT_STATE.md"
  ],
  "scripts": {
    "start": "node backend/mcp.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint backend/mcp.js backend/lib/ benchmarks/run.js tests/ --ext .js",
    "lint:fix": "eslint backend/mcp.js backend/lib/ benchmarks/run.js tests/ --fix --ext .js",
    "benchmark": "node benchmarks/run.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "esbuild": "^0.28.1",
    "zod": "^3.24.2"
  },
  "keywords": [
    "mcp",
    "agentic",
    "perception",
    "semantic",
    "token-optimization",
    "ai-agents"
  ],
  "author": "Shawn Nichols Sr. (Nichols Transco LLC)",
  "license": "MIT",
  "devDependencies": {
    "@dqbd/tiktoken": "^1.0.22",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  }
}
